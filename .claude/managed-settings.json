{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",

	"disableBypassPermissionsMode": "disable",
	"allowManagedPermissionRulesOnly": true,

	"defaultMode": "default",

	"permissions": {
		"ask": ["Bash", "Edit"],
		"deny": [
			"WebFetch",
			"Bash(curl *)",
			"Bash(wget *)",
			"Read(./.env)",
			"Read(./.env.*)",
			"Read(./secrets/**)",
			"Read(./config/secrets/**)"
		]
	},

	"sandbox": {
		"enabled": true,
		"network": {
			"allowedDomains": []
		}
	}
}
